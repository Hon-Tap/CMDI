{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    /* Next.js + TS defaults (safe + modern) */
    "target": "ES2020",
    "lib": [
      "DOM",
      "DOM.Iterable",
      "ESNext"
    ],
    "module": "ESNext",
    "moduleResolution": "bundler",
    /* App Router works best with these */
    "jsx": "react-jsx",
    "isolatedModules": true,
    "noEmit": true,
    /* Interop + JSON */
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    /* Quality */
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    /* JS allowed (optional) */
    "allowJs": true,
    "checkJs": false,
    /* Faster editor builds */
    "incremental": true,
    /* Path alias */
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./*"
      ]
    },
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "types/**/*.d.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
