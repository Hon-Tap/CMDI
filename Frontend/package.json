{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@11.6.2",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "next dev --webpack",
    "dev:turbo": "next dev --turbopack",

    "build": "next build --webpack",
    "build:turbo": "next build --turbopack",

    "start": "next start",

    "lint": "next lint",

    "clean": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true}); console.log('deleted .next')\"",
    "build:diag": "next build --webpack 2>&1 | tee build_diag.log"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "framer-motion": "^12.29.0",
    "jose": "^6.1.3",
    "lucide-react": "^0.563.0",
    "next": "16.1.6",
    "pg": "^8.18.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20.17.17",
    "@types/pg": "^8.11.0",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "typescript": "^5.9.3"
  }
}
