# ==============================================================================
# CORE SECRETS & ENV
# ==============================================================================

# Env files
.env
.env.*
!.env.example

# Local overrides
*.local

# Private keys / certs
*.pem
*.key

# Common secret folders/files (kept broad but not ridiculous)
**/secrets/**
**/*secret*


# ==============================================================================
# NODE / NEXT.JS (any folder)
# ==============================================================================

# Dependencies
node_modules/
**/node_modules/

# Next.js build output
.next/
**/.next/

# Common build outputs
out/
dist/
build/


# ==============================================================================
# VERCEL / NETLIFY / DEPLOY
# ==============================================================================

.vercel/
.netlify/


# ==============================================================================
# TURBO / CACHES
# ==============================================================================

.turbo/
**/.turbo/

.cache/
**/.cache/

# Common tool caches
.eslintcache
.stylelintcache


# ==============================================================================
# BACKEND (PHP)
# ==============================================================================

vendor/
**/vendor/
composer.phar
.phpunit.result.cache


# ==============================================================================
# LOGS & DEBUG
# ==============================================================================

*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
*.tsbuildinfo


# ==============================================================================
# TESTING / COVERAGE
# ==============================================================================

coverage/
.nyc_output/


# ==============================================================================
# OS & IDE JUNK
# ==============================================================================

.DS_Store
Thumbs.db
desktop.ini

.vscode/
.idea/
*.swp
*.swo

# Office temp files
~$*
*.tmp
*.temp
